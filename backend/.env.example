# Copy to .env and fill in values. Never commit .env.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_SECONDS=120

# Optional: comma-separated origins for browser access
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend runs on port 8001 by default (avoids conflict with other apps on 8000)

# true = show AI rationale / "more detail" evaluation in the UI. Omit or false = gentler UX (follow-ups only).
# SAFEDEVOPS_DEBUG_MODE=true

# Optional paths (defaults are relative to the backend package layout)
# DATABASE_URL=sqlite:///./safedevops_pilot.db
